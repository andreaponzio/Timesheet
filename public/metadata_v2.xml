<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0"
           xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">

    <edmx:DataServices m:DataServiceVersion="2.0"
                       xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">

        <Schema Namespace="Timesheet"
                xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

            <!-- ============================
                 ENTITY: CUSTOMER
            ============================ -->
            <EntityType Name="Customer">
                <Key>
                    <PropertyRef Name="id"/>
                </Key>

                <Property Name="id" Type="Edm.Int32" Nullable="false"/>
                <Property Name="description" Type="Edm.String" Nullable="false"/>
                <Property Name="changed_on" Type="Edm.DateTime" Nullable="false"/>

                <NavigationProperty Name="Wbs"
                                    Relationship="Timesheet.Customer_Wbs"
                                    FromRole="Customer"
                                    ToRole="Wbs"/>
            </EntityType>

            <!-- ============================
                 ENTITY: WBS
            ============================ -->
            <EntityType Name="Wbs">
                <Key>
                    <PropertyRef Name="internal_ref"/>
                </Key>

                <Property Name="internal_ref" Type="Edm.String" Nullable="false"/>
                <Property Name="customer" Type="Edm.Int32" Nullable="false"/>
                <Property Name="description1" Type="Edm.String" Nullable="false"/>
                <Property Name="description2" Type="Edm.String"/>
                <Property Name="status" Type="Edm.Int32" Nullable="false"/>
                <Property Name="id" Type="Edm.Int32" Nullable="false"/>
                <Property Name="changed_on" Type="Edm.DateTime" Nullable="false"/>

                <NavigationProperty Name="Activity"
                                    Relationship="Timesheet.Wbs_Activity"
                                    FromRole="Wbs"
                                    ToRole="Activity"/>
            </EntityType>

            <!-- ============================
                 ENTITY: ACTIVITY
            ============================ -->
            <EntityType Name="Activity">
                <Key>
                    <PropertyRef Name="wbs"/>
                    <PropertyRef Name="internal_ref"/>
                </Key>

                <Property Name="wbs" Type="Edm.Int32" Nullable="false"/>
                <Property Name="internal_ref" Type="Edm.String" Nullable="false"/>
                <Property Name="external_ref" Type="Edm.String" Nullable="false"/>
                <Property Name="type" Type="Edm.Int32" Nullable="false"/>
                <Property Name="description" Type="Edm.String" Nullable="false"/>
                <Property Name="functional" Type="Edm.String"/>
                <Property Name="technical" Type="Edm.String"/>
                <Property Name="hour" Type="Edm.Decimal"/>
                <Property Name="mergenote" Type="Edm.String"/>
                <Property Name="status" Type="Edm.Int32" Nullable="false"/>
                <Property Name="note" Type="Edm.String"/>
                <Property Name="id" Type="Edm.Int32" Nullable="false"/>
                <Property Name="changed_on" Type="Edm.DateTime" Nullable="false"/>

                <NavigationProperty Name="Request"
                                    Relationship="Timesheet.Activity_Request"
                                    FromRole="Activity"
                                    ToRole="Request"/>

                <NavigationProperty Name="Workday"
                                    Relationship="Timesheet.Activity_Workday"
                                    FromRole="Activity"
                                    ToRole="Workday"/>
            </EntityType>

            <!-- ============================
                 ENTITY: WORKDAY
            ============================ -->
            <EntityType Name="Workday">
                <Key>
                    <PropertyRef Name="id"/>
                </Key>

                <Property Name="id" Type="Edm.Int32" Nullable="false"/>
                <Property Name="activity" Type="Edm.Int32" Nullable="false"/>
                <Property Name="date" Type="Edm.DateTime" Nullable="false"/>
                <Property Name="idgroup" Type="Edm.Int32" Nullable="false"/>
                <Property Name="hour" Type="Edm.Decimal"/>
                <Property Name="extrainfo" Type="Edm.Int32" Nullable="false"/>
                <Property Name="place" Type="Edm.String"/>
                <Property Name="note" Type="Edm.String"/>
                <Property Name="changed_on" Type="Edm.DateTime" Nullable="false"/>
            </EntityType>

            <!-- ============================
                 ENTITY: REQUEST
            ============================ -->
            <EntityType Name="Request">
                <Key>
                    <PropertyRef Name="activity"/>
                    <PropertyRef Name="request"/>
                </Key>

                <Property Name="activity" Type="Edm.Int32" Nullable="false"/>
                <Property Name="request" Type="Edm.String" Nullable="false"/>
                <Property Name="type" Type="Edm.Int32" Nullable="false"/>
                <Property Name="status" Type="Edm.Int32" Nullable="false"/>
                <Property Name="description" Type="Edm.String" Nullable="false"/>
                <Property Name="owner" Type="Edm.String"/>
                <Property Name="date" Type="Edm.DateTime" Nullable="false"/>
                <Property Name="id" Type="Edm.Int32" Nullable="false"/>
                <Property Name="changed_on" Type="Edm.DateTime" Nullable="false"/>
            </EntityType>

            <!-- ============================
                 ASSOCIATIONS (OData V2)
            ============================ -->

            <Association Name="Customer_Wbs">
                <End Type="Timesheet.Customer" Multiplicity="1" Role="Customer"/>
                <End Type="Timesheet.Wbs" Multiplicity="*" Role="Wbs"/>
            </Association>

            <Association Name="Wbs_Activity">
                <End Type="Timesheet.Wbs" Multiplicity="1" Role="Wbs"/>
                <End Type="Timesheet.Activity" Multiplicity="*" Role="Activity"/>
            </Association>

            <Association Name="Activity_Request">
                <End Type="Timesheet.Activity" Multiplicity="1" Role="Activity"/>
                <End Type="Timesheet.Request" Multiplicity="*" Role="Request"/>
            </Association>

            <Association Name="Activity_Workday">
                <End Type="Timesheet.Activity" Multiplicity="1" Role="Activity"/>
                <End Type="Timesheet.Workday" Multiplicity="*" Role="Workday"/>
            </Association>

            <!-- ============================
                 ENTITY CONTAINER
            ============================ -->
            <EntityContainer Name="Container">

                <EntitySet Name="Customer" EntityType="Timesheet.Customer"/>
                <EntitySet Name="Wbs" EntityType="Timesheet.Wbs"/>
                <EntitySet Name="Activity" EntityType="Timesheet.Activity"/>
                <EntitySet Name="Workday" EntityType="Timesheet.Workday"/>
                <EntitySet Name="Request" EntityType="Timesheet.Request"/>

                <AssociationSet Name="Customer_WbsSet"
                                Association="Timesheet.Customer_Wbs">
                    <End Role="Customer" EntitySet="Customer"/>
                    <End Role="Wbs" EntitySet="Wbs"/>
                </AssociationSet>

                <AssociationSet Name="Wbs_ActivitySet"
                                Association="Timesheet.Wbs_Activity">
                    <End Role="Wbs" EntitySet="Wbs"/>
                    <End Role="Activity" EntitySet="Activity"/>
                </AssociationSet>

                <AssociationSet Name="Activity_RequestSet"
                                Association="Timesheet.Activity_Request">
                    <End Role="Activity" EntitySet="Activity"/>
                    <End Role="Request" EntitySet="Request"/>
                </AssociationSet>

                <AssociationSet Name="Activity_WorkdaySet"
                                Association="Timesheet.Activity_Workday">
                    <End Role="Activity" EntitySet="Activity"/>
                    <End Role="Workday" EntitySet="Workday"/>
                </AssociationSet>

            </EntityContainer>

        </Schema>
    </edmx:DataServices>
</edmx:Edmx>