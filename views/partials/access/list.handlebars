<h6>Controllo accessi</h6>
<ul class="list-group p-2 css-font-size-95">
   <form id="form" action="/access" method="post">
      <div class="d-flex d-inline-row justify-content-center">
         <select class="form-select" id="customer" name="customer" required>
            <option value="" selected>Seleziona un cliente</option>
            {{#each data}}
               <option value="{{id}}">{{description}}
               </option>
            {{/each}}
         </select>
         <button type="submit" class="btn btn-success mx-1">
            <i class="bi bi-check2-square"></i>
         </button>
         <a href="/" type="button" class="d-inline-flex btn btn-secondary">
            <i class="bi bi-x-square"></i>
         </a>
      </div>
   </form>
</ul>