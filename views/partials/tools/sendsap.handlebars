<h6>Rigenerazione indici</h6>
<ul class="list-group p-2 css-font-size-95">
   <form id="form" action="/tools/sendsap" method="post">

      <!-- Sistemi SAP -->
      <div class="d-flex d-flex-row mb-1">
         <div class="css-flex-30">
            <label for="sap" class="form-label">Sistema SAP</label>
            <select class="form-select" id="sap" name="sap" required>
               <option value="" selected>Seleziona un sistema</option>
               {{#each data}}
                  <option value="{{id}}">{{description}}
                  </option>
               {{/each}}
            </select>
         </div>
      </div>

      <!-- Clienti -->
      <div class="form-check">
         <input class="form-check-input" type="checkbox" id="customer" name="customer">
         <label class="form-check-label" for="customer">
            Clienti
         </label>
      </div>

      <!-- WBS -->
      <div class="form-check">
         <input class="form-check-input" type="checkbox" id="wbs" name="wbs">
         <label class="form-check-label" for="wbs">
            Commesse
         </label>
      </div>

      <!-- Attività -->
      <div class="form-check">
         <input class="form-check-input" type="checkbox" id="activity" name="activity">
         <label class="form-check-label" for="activity">
            Attività
         </label>
      </div>

      <!-- Richieste di trasporto -->
      <div class="form-check">
         <input class="form-check-input" type="checkbox" id="request" name="request">
         <label class="form-check-label" for="request">
            Richieste di trasporto
         </label>
      </div>

      <!-- Consuntivazione -->
      <div class="form-check">
         <input class="form-check-input" type="checkbox" id="workday" name="workday">
         <label class="form-check-label" for="workday">
            Consuntivazione
         </label>
      </div>

      <!-- Save or Cancel -->
      <div class="d-flex d-inline-row mt-2">
         <div class="spinner-border" role="status" id="wait" hidden></div>
         <button type="button" class="btn btn-success me-1" id="index" onclick="generate();">
            <i class="bi bi-upload"></i>
         </button>
         <div id="cancel">
            <a href="/" type="button" class="d-inline-flex btn btn-secondary">
               <i class="bi bi-x-square"></i>
            </a>
         </div>
      </div>
   </form>
</ul>

<script>
   function generate() {
      document.querySelector("#index").hidden = true;
      document.querySelector("#cancel").hidden = true;
      document.querySelector("#wait").hidden = false;
      document.querySelector("#form").submit();
   }
</script>