<div class="modal fade" id="AddGroup" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
     aria-labelledby="staticAddGroupLabel" aria-hidden="true">
   <div class="modal-dialog">
      <div class="modal-content">
         <div class="modal-header">
            <h1 class="modal-title fs-5">Aggiunta attività d un Gruppo</h1>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
         </div>
         <div class="modal-body">
            <div class="d-flex d-flex-row">
               <div class="flex-grow-1 ms-2">
                  <select class="form-select" id="group" name="group" required>
                     <option value="" selected>Seleziona il gruppo</option>
                     {{#each data.group_list}}
                        <option value="{{id}}">{{description}}</option>
                     {{/each}}
                  </select>
               </div>
            </div>
         </div>
         <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
               <i class="bi bi-x-square"></i>
            </button>
            <button type="button" class="btn btn-success" onclick="modalRapidSubmit(3);">
               <i class="bi bi-floppy"></i>
            </button>
         </div>
      </div>
   </div>
</div>